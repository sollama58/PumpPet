{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo",
    "target": "es2023",
    "lib": ["ES2023"],
    "skipLibCheck": true,

    /* Bundler mode */
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,

    /* Explicit paths for packages that lack a "types" export condition in Vite 8 */
    "baseUrl": ".",
    "paths": {
      "vite":                   ["./node_modules/vite/dist/node/index.d.ts"],
      "@vitejs/plugin-react":   ["./node_modules/@vitejs/plugin-react/dist/index.d.ts"],
      "@tailwindcss/vite":      ["./node_modules/@tailwindcss/vite/dist/index.d.mts"]
    },

    /* Linting */
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["vite.config.ts"]
}
